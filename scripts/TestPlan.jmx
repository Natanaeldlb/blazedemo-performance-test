<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="BlazeDemo Performance Test"/>

    <hashTree>

      <!-- THREAD GROUP (CARGA) -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Carga 250 RPS">
        <intProp name="ThreadGroup.num_threads">200</intProp>
          <intProp name="ThreadGroup.ramp_time">20</intProp>

      <!-- ATIVA CONTROLE POR TEMPO -->
      <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">120</stringProp>
          <stringProp name="ThreadGroup.delay">0</stringProp>

      <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
      <!-- LOOP INFINITO CONTROLADO PELO TEMPO -->
        <stringProp name="LoopController.loops">-1</stringProp>
          <boolProp name="LoopController.continue_forever">true</boolProp>
        </elementProp>
      </ThreadGroup>

      <hashTree>

        <!-- CONTROLE DE THROUGHPUT -->
        <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer">
          <doubleProp>
            <name>throughput</name>
            <value>15000</value>
          </doubleProp>
          <intProp name="calcMode">1</intProp>
        </ConstantThroughputTimer>

        <hashTree/>

        <!-- CONFIG BASE -->
        <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Defaults">
          <stringProp name="HTTPSampler.domain">www.blazedemo.com</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </ConfigTestElement>

        <hashTree/>

        <!-- BUSCAR VOOS -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Buscar voos">
          <stringProp name="HTTPSampler.path">/reserve.php</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>

          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="fromPort" elementType="HTTPArgument">
                <stringProp name="Argument.value">Boston</stringProp>
              </elementProp>
              <elementProp name="toPort" elementType="HTTPArgument">
                <stringProp name="Argument.value">London</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>

        <hashTree>

          <!-- CORRELAÇÃO -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extrair flightId">
            <stringProp name="RegexExtractor.refname">flightId</stringProp>
            <stringProp name="RegexExtractor.regex">name="flight" value="(.*?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
          </RegexExtractor>

          <hashTree/>

        </hashTree>

        <!-- SELECIONAR VOO -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Selecionar voo">
          <stringProp name="HTTPSampler.path">/purchase.php</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>

          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="flight" elementType="HTTPArgument">
                <stringProp name="Argument.value">${flightId}</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>

        <hashTree/>

        <!-- FINALIZAR COMPRA -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Finalizar compra">
          <stringProp name="HTTPSampler.path">/confirmation.php</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>

          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">

              <elementProp name="inputName" elementType="HTTPArgument">
                <stringProp name="Argument.value">Natanael Lima</stringProp>
              </elementProp>

              <elementProp name="address" elementType="HTTPArgument">
                <stringProp name="Argument.value">Rua Teste</stringProp>
              </elementProp>

              <elementProp name="city" elementType="HTTPArgument">
                <stringProp name="Argument.value">Manaus</stringProp>
              </elementProp>

              <elementProp name="state" elementType="HTTPArgument">
                <stringProp name="Argument.value">AM</stringProp>
              </elementProp>

              <elementProp name="zipCode" elementType="HTTPArgument">
                <stringProp name="Argument.value">69000-000</stringProp>
              </elementProp>

              <elementProp name="creditCardNumber" elementType="HTTPArgument">
                <stringProp name="Argument.value">4111111111111111</stringProp>
              </elementProp>

              <elementProp name="creditCardMonth" elementType="HTTPArgument">
                <stringProp name="Argument.value">12</stringProp>
              </elementProp>

              <elementProp name="creditCardYear" elementType="HTTPArgument">
                <stringProp name="Argument.value">2026</stringProp>
              </elementProp>

              <elementProp name="nameOnCard" elementType="HTTPArgument">
                <stringProp name="Argument.value">Teste QA</stringProp>
              </elementProp>

            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>

        <hashTree>

          <!-- VALIDAÇÃO -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Compra realizada com sucesso">
            <collectionProp name="Assertion.test_strings">
              <stringProp name="0">Thank you for your purchase!</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>

          <hashTree/>

        </hashTree>

        <!-- RELATÓRIO -->
        <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report">
          <stringProp name="filename">results.jtl</stringProp>
        </ResultCollector>

        <hashTree/>

      </hashTree>

    </hashTree>

  </hashTree>
</jmeterTestPlan>